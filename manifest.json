      "resources": [
        "icons/icon128.png",
        "images/logo.png",
        "images/logo/*.webp",
        "images/logo/*.svg",
        "js/runner/languages/javascript/sandbox.html",
        "js/runner/languages/javascript/sandbox-script.js",
        "js/runner/languages/typescript/sandbox.html",
