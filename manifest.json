  "name": "__MSG_extName__",
  "short_name": "Timeline",
  "version": "4.6.9",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "author": "yanchao hou",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "permissions": [
    "storage",
    "unlimitedStorage",
    "identity",
    "activeTab"
