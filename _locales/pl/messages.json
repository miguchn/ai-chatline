  "aboutTabName": {
    "message": "O wtyczce"
  },
  "aboutPluginTitle": {
    "message": "O rozszerzeniu"
  },
  "aboutPluginContent": {
    "message": "Timeline to rozszerzenie zwiększające produktywność w rozmowach z AI w przeglądarce, z osią czasu, folderami, podświetlaniem tekstu, kopiowaniem formuł LaTeX, własnymi promptami i wieloma innymi funkcjami — maksymalna wydajność. Obsługuje ChatGPT, Gemini, Claude, DeepSeek, Kimi, Doubao, Qwen i wszystkie główne platformy AI."
  },
  "aboutDataSecurityTitle": {
    "message": "Bezpieczeństwo danych"
  },
  "aboutDataSecurityContent": {
    "message": "Wszystkie Twoje dane są przechowywane lokalnie w przeglądarce lub na Twoim Google Drive. Rozszerzenie nie zbiera, nie przesyła ani nie udostępnia żadnych treści rozmów ani danych osobowych. Projekt jest open-source na GitHubie, a kod jest dostępny do przeglądu w każdej chwili."
  },
  "aboutDeveloperTitle": {
    "message": "Feedback"
  },
  "aboutDeveloperContent": {
    "message": "Ten projekt jest wspólnie utrzymywany przeze mnie i Claude Opus 4.6, w rytmie 1–2 nowych wersji tygodniowo. Aby poprosić o funkcję lub zgłosić błąd, skontaktuj się ze mną przez poniższe kanały (na pewno odpiszę, gdy to zobaczę):"
  },
  "aboutShareTitle": {
    "message": "Poleć znajomym"
  },
  "aboutShareContent": {
    "message": "Jeśli Timeline jest dla Ciebie przydatny, zachęcam do napisania recenzji na Xiaohongshu, Bilibili, X, Reddit, YouTube lub innych platformach, a także do udostępnienia go kolegom i znajomym, aby więcej osób mogło z niego korzystać. Dziękuję. ❤️"
  },
