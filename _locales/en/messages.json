  "aboutTabName": {
    "message": "About"
  },
  "aboutPluginTitle": {
    "message": "About This Extension"
  },
  "aboutPluginContent": {
    "message": "Timeline is a productivity plugin built for browser-based AI conversations, featuring timeline, folders, text highlighting, LaTeX formula copying, custom prompts, and more — supercharging your efficiency. Works with ChatGPT, Gemini, Claude, DeepSeek, Kimi, Doubao, Qwen, and all major AI platforms."
  },
  "aboutDataSecurityTitle": {
    "message": "Data Security"
  },
  "aboutDataSecurityContent": {
    "message": "All your data is stored locally in your browser or in your Google Drive. The extension does not collect, upload, or share any of your conversation content or personal information. This project is open-source on GitHub, and the code is available for review at any time."
  },
  "aboutDeveloperTitle": {
    "message": "Feedback"
  },
  "aboutDeveloperContent": {
    "message": "This project is co-maintained by me and Claude Opus 4.6, with 1–2 new versions released every week. To request a feature or report a bug, reach out through the channels below (I will definitely reply when I see it):"
  },
  "aboutShareTitle": {
    "message": "Recommend to Friends"
  },
  "aboutShareContent": {
    "message": "If you find Timeline useful, feel free to post a recommendation on Xiaohongshu, Bilibili, X, Reddit, YouTube, or other platforms, and share it with friends and classmates so more people can use it. Thanks. ❤️"
  },
